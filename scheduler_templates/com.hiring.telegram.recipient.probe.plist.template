<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>com.hiring.telegram.recipient.probe</string>

    <key>ProgramArguments</key>
    <array>
        <string>__LOCAL_LAUNCHER_PATH__</string>
        <string>run-probe</string>
    </array>

    <key>WorkingDirectory</key>
    <string>__LOCAL_LAUNCHER_DIR__</string>

    <!-- 每 1 小時讀取一次 Telegram /start updates，只更新 telegram_recipients.json -->
    <key>StartInterval</key>
    <integer>3600</integer>

    <key>StandardOutPath</key>
    <string>__LOCAL_LOG_DIR__/telegram_probe_stdout.log</string>

    <key>StandardErrorPath</key>
    <string>__LOCAL_LOG_DIR__/telegram_probe_stderr.log</string>

    <key>EnvironmentVariables</key>
    <dict>
        <key>PATH</key>
        <string>/usr/local/bin:/usr/bin:/bin:/usr/sbin:/sbin</string>
        <key>LANG</key>
        <string>zh_TW.UTF-8</string>
    </dict>
</dict>
</plist>
